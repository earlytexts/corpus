{
  "name": "@earlytexts/corpus",
  "version": "0.5.0",
  "description": "The Early Text Corpus: catalogue, schema, path, and validation logic, published as compiled JS + type declarations (see src/index.ts)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wire": {
      "types": "./dist/wire.d.ts",
      "default": "./dist/wire.js"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "default": "./dist/build.js"
    },
    "./harness": {
      "types": "./dist/harness.d.ts",
      "default": "./dist/harness.js"
    }
  },
  "scripts": {
    "build": "node scripts/build.ts",
    "build:pkg": "tsup",
    "fix": "node scripts/fix.ts",
    "test": "vitest run tests/catalogue.test.ts tests/hints.test.ts",
    "validate": "vitest run tests/validate.test.ts",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run check && npm run build:pkg && npm test"
  },
  "dependencies": {
    "@earlytexts/markit": "^3.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.1",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
