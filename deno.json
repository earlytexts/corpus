{
  "name": "@earlytexts/corpus",
  "version": "0.13.0",
  "license": "MIT",
  "description": "The wire contract for the Early Text Centre's compiled corpus catalogue: read-side types, (de)serialisation, word semantics, and dictionary resolution, plus an in-memory corpus builder for tests.",
  "exports": {
    "./wire": "./src/wire.ts",
    "./test": "./src/test.ts"
  },
  "publish": {
    "include": ["src/", "README.md", "LICENSE.md", "deno.json"],
    "exclude": [
      "src/index.ts",
      "src/build.ts",
      "src/fs.ts",
      "src/catalogue/write.ts",
      "src/validation/",
      "src/dictionary/account.ts"
    ]
  },
  "imports": {
    "@earlytexts/markit": "jsr:@earlytexts/markit@^4.1.0",
    "@std/expect": "jsr:@std/expect@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0"
  },
  "tasks": {
    "build": "deno run --allow-read --allow-write scripts/build.ts",
    "test": "deno test --allow-read tests/",
    "test:coverage": "deno test --allow-read --coverage=coverage tests/ && deno coverage coverage",
    "check": "deno check src/ scripts/ tests/ && deno lint",
    "fmt": "deno fmt && deno run --allow-read --allow-write scripts/fmt.ts",
    "fmt:check": "deno fmt --check && deno run --allow-read scripts/fmt.ts --check"
  },
  "compilerOptions": {
    "strict": true,
    "verbatimModuleSyntax": true
  },
  "exclude": [
    "data/",
    "catalogue/",
    "node_modules/",
    "coverage/",
    "compositor/"
  ],
  "fmt": {
    "exclude": ["*.md"]
  }
}
